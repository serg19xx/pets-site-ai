# Optional: copy to `.env` in repo root when you want custom Postgres/API settings.
# Then run: docker compose --env-file .env up -d
# Without this file, `docker compose up` uses defaults from docker-compose.yml (password pets_dev_change_me).
# Do not commit `.env`.

# PostgreSQL
POSTGRES_USER=pets
POSTGRES_PASSWORD=change_me_in_prod
POSTGRES_DB=pets
# POSTGRES_PORT=5432

# API container host port
# API_PORT=8080
