# Backend: copy to .env (do not commit .env).
# Use a single DATABASE_URL so switching Docker Postgres ↔ Supabase is an env change, not a code change.

PORT=8080

# Default when Postgres runs via `docker compose up` WITHOUT a root `.env` (Compose defaults: user pets, password pets_dev_change_me, db pets).
DATABASE_URL=postgresql://pets:pets_dev_change_me@127.0.0.1:5432/pets

# If you use a root `.env` with POSTGRES_PASSWORD=mysecret, use the same password here:
# DATABASE_URL=postgresql://pets:mysecret@127.0.0.1:5432/pets

# --- Same Compose network (API runs as `api` service in docker-compose) ---
# DATABASE_URL=postgresql://pets:pets_dev_change_me@postgres:5432/pets

# --- Supabase (Project Settings → Database → connection string / pooler) ---
# DATABASE_URL=postgresql://postgres.[ref]:[PASSWORD]@[host]:6543/postgres
